---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  description,
  canonical = 'https://home.spampishing.com/',
  ogImage = 'https://home.spampishing.com/og-image.png',
} = Astro.props;

const pathname = new URL(Astro.request.url).pathname;

const navLinks = [
  { href: '/',         label: 'Home' },
  { href: '/privacy',  label: 'Privacy Policy' },
  { href: '/terms',    label: 'Terms' },
  { href: '/contact',  label: 'Contact' },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#fafafa" id="theme-color-meta" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />
    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonical} />
    <meta property="og:site_name"   content="Spam Detector" />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImage} />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />
    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImage} />
    <!-- Favicons -->
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="SpamCheck" />
    <link rel="manifest" href="/site.webmanifest" />
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />
    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      (function(){var s=localStorage.getItem('theme'),d=window.matchMedia('(prefers-color-scheme: dark)').matches;if(s==='dark'||(!s&&d))document.documentElement.classList.add('dark')})();
    </script>
  </head>

  <body class="bg-[#fafafa] dark:bg-[#0a0a0a] min-h-screen font-sans antialiased flex flex-col transition-colors duration-200">

    <!-- Skip link -->
    <a href="#main-content"
       class="sr-only focus-visible:not-sr-only focus-visible:fixed focus-visible:top-4 focus-visible:left-4 focus-visible:z-50
              focus-visible:px-4 focus-visible:py-2 focus-visible:bg-[#171717] focus-visible:text-white focus-visible:rounded-full
              focus-visible:text-sm focus-visible:font-medium">
      Skip to main content
    </a>

    <!-- Header -->
    <header class="sticky top-0 z-40 bg-[#fafafa]/80 dark:bg-[#0a0a0a]/80 backdrop-blur-md border-b border-[#ebebeb] dark:border-[#2e2e2e]">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2.5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#171717] dark:focus-visible:ring-[#ededed] rounded-[6px]">
          <div class="w-7 h-7 bg-[#171717] dark:bg-[#ededed] rounded-[6px] flex items-center justify-center flex-shrink-0">
            <svg class="w-3.5 h-3.5 text-white dark:text-[#0a0a0a]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <span class="text-[15px] font-semibold tracking-[-0.3px] text-[#171717] dark:text-[#ededed]">Spam Detector</span>
        </a>
        <div class="flex items-center gap-3">
          <nav class="hidden sm:flex items-center gap-1" aria-label="Site navigation">
            {navLinks.filter(l => l.href !== '/').map(l => (
              <a
                href={l.href}
                class={`px-3 py-1.5 rounded-[6px] text-[13px] transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#171717] dark:focus-visible:ring-[#ededed]
                  ${pathname === l.href
                    ? 'text-[#171717] dark:text-[#ededed] bg-[#f5f5f5] dark:bg-[#1a1a1a] font-medium'
                    : 'text-[#888] dark:text-[#666] hover:text-[#171717] dark:hover:text-[#ededed] hover:bg-[#f5f5f5] dark:hover:bg-[#1a1a1a]'}`}
              >{l.label}</a>
            ))}
          </nav>
          <button
            type="button" id="theme-toggle"
            class="w-8 h-8 flex items-center justify-center rounded-[6px] border border-[#ebebeb] dark:border-[#2e2e2e]
                   text-[#888] dark:text-[#666] hover:text-[#171717] dark:hover:text-[#ededed]
                   hover:bg-[#f5f5f5] dark:hover:bg-[#1a1a1a] transition-colors
                   focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#171717] dark:focus-visible:ring-[#ededed]"
            style="touch-action:manipulation" aria-label="Switch to dark mode">
            <svg id="icon-moon" class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
            </svg>
            <svg id="icon-sun" class="w-3.5 h-3.5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
            </svg>
          </button>
        </div>
      </div>
    </header>

    <!-- Page content -->
    <slot />

    <!-- Footer -->
    <footer class="mt-auto border-t border-[#ebebeb] dark:border-[#2e2e2e]">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 py-8">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-6">
          <div>
            <div class="flex items-center gap-2 mb-1">
              <div class="w-5 h-5 bg-[#171717] dark:bg-[#ededed] rounded-[4px] flex items-center justify-center flex-shrink-0">
                <svg class="w-3 h-3 text-white dark:text-[#0a0a0a]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                </svg>
              </div>
              <span class="text-[13px] font-semibold text-[#171717] dark:text-[#ededed]">Spam Detector</span>
            </div>
            <p class="text-[12px] text-[#888] dark:text-[#666]">AI-powered phishing &amp; spam detection. Free, no sign-up.</p>
          </div>
          <nav class="flex flex-wrap gap-x-5 gap-y-2" aria-label="Footer navigation">
            {navLinks.map(l => (
              <a
                href={l.href}
                class={`text-[13px] transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#171717] dark:focus-visible:ring-[#ededed] rounded
                  ${pathname === l.href
                    ? 'text-[#171717] dark:text-[#ededed] font-medium'
                    : 'text-[#888] dark:text-[#666] hover:text-[#171717] dark:hover:text-[#ededed]'}`}
              >{l.label}</a>
            ))}
          </nav>
          <p class="text-[12px] text-[#888] dark:text-[#666] whitespace-nowrap">&copy; {new Date().getFullYear()} Spam Detector</p>
        </div>
      </div>
    </footer>

  </body>
</html>

<script>
  const html  = document.documentElement;
  const btn   = document.getElementById('theme-toggle') as HTMLButtonElement;
  const moon  = document.getElementById('icon-moon')!;
  const sun   = document.getElementById('icon-sun')!;
  const meta  = document.querySelector('meta[name="theme-color"]') as HTMLMetaElement;

  function applyTheme(dark: boolean) {
    html.classList.toggle('dark', dark);
    moon.classList.toggle('hidden', dark);
    sun.classList.toggle('hidden', !dark);
    if (meta) meta.content = dark ? '#0a0a0a' : '#fafafa';
    btn.setAttribute('aria-label', dark ? 'Switch to light mode' : 'Switch to dark mode');
  }

  applyTheme(html.classList.contains('dark'));

  btn.addEventListener('click', () => {
    const isDark = html.classList.contains('dark');
    applyTheme(!isDark);
    localStorage.setItem('theme', isDark ? 'light' : 'dark');
  });
</script>
