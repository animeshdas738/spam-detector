---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="404 — Page Not Found | Spam Detector"
  description="The page you're looking for doesn't exist. Head back to Spam Detector to analyse phishing emails, spam links, and suspicious content."
  canonical="https://home.spampishing.com/404"
>
  <main id="main-content" class="flex-1 flex items-center justify-center px-4 sm:px-6 py-20">
    <div class="text-center max-w-md">

      <!-- Large muted number -->
      <p class="font-mono text-[80px] sm:text-[96px] font-semibold leading-none
                 text-[#ebebeb] dark:text-[#2e2e2e] select-none mb-6" aria-hidden="true">
        404
      </p>

      <!-- Icon -->
      <div class="w-12 h-12 bg-[#f5f5f5] dark:bg-[#1a1a1a] rounded-xl flex items-center justify-center mx-auto mb-5">
        <svg class="w-6 h-6 text-[#888] dark:text-[#666]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
            d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>

      <h1 class="text-[22px] font-semibold text-[#171717] dark:text-[#ededed] tracking-[-0.5px] text-pretty mb-2">
        Page Not Found
      </h1>
      <p class="text-[14px] text-[#888] dark:text-[#666] leading-relaxed mb-8">
        The page you're looking for doesn't exist or has been moved.
        Let's get you back to detecting phishing and spam.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="/"
          class="w-full sm:w-auto px-6 h-10 bg-[#171717] dark:bg-[#ededed] hover:bg-[#333] dark:hover:bg-white
                 text-white dark:text-[#0a0a0a] rounded-full text-[14px] font-medium transition-colors
                 flex items-center justify-center gap-2
                 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#171717] dark:focus-visible:ring-[#ededed] focus-visible:ring-offset-2"
        >
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
          Back to Home
        </a>
        <a
          href="/contact"
          class="w-full sm:w-auto px-6 h-10 border border-[#ebebeb] dark:border-[#2e2e2e]
                 bg-white dark:bg-transparent hover:bg-[#fafafa] dark:hover:bg-[#1a1a1a]
                 text-[#171717] dark:text-[#ededed] rounded-full text-[14px] font-medium transition-colors
                 flex items-center justify-center
                 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#171717] dark:focus-visible:ring-[#ededed] focus-visible:ring-offset-1"
        >
          Report a Broken Link
        </a>
      </div>

    </div>
  </main>
</Layout>
