---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact Us — Spam Detector"
  description="Get in touch with the Spam Detector team. Report false positives, request features, or ask questions about our free phishing and spam detection tool."
  canonical="https://spamdetector.app/contact"
>
  <main id="main-content" class="max-w-3xl mx-auto px-4 sm:px-6 py-10 flex-1">

    <div class="mb-8">
      <p class="font-mono text-[10px] text-[#888] dark:text-[#666] uppercase tracking-widest mb-1.5">Get in Touch</p>
      <h1 class="text-[28px] font-semibold text-[#171717] dark:text-[#ededed] tracking-[-0.7px] text-pretty">Contact Us</h1>
      <p class="mt-2 text-[14px] text-[#4d4d4d] dark:text-[#a0a0a0] leading-relaxed max-w-xl">
        Have a question, spotted a false positive, or want to suggest a feature?
        We'd love to hear from you. Fill in the form below and we'll respond as soon as possible.
      </p>
    </div>

    <div class="grid sm:grid-cols-3 gap-6">

      <!-- Contact Info Cards -->
      <div class="sm:col-span-1 space-y-3">
        <div class="bg-white dark:bg-[#111111] rounded-[8px] border border-[#ebebeb] dark:border-[#2e2e2e] p-4
                    shadow-[0_1px_1px_rgba(0,0,0,0.02),0_2px_2px_rgba(0,0,0,0.04)]">
          <div class="w-7 h-7 border border-[#ebebeb] dark:border-[#2e2e2e] rounded-[6px] flex items-center justify-center mb-3">
            <svg class="w-3.5 h-3.5 text-[#171717] dark:text-[#ededed]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <h2 class="text-[13px] font-semibold text-[#171717] dark:text-[#ededed] mb-0.5 tracking-[-0.2px]">General</h2>
          <p class="text-[12px] text-[#888] dark:text-[#666] leading-relaxed">hello@spamdetector.app</p>
        </div>
        <div class="bg-white dark:bg-[#111111] rounded-[8px] border border-[#ebebeb] dark:border-[#2e2e2e] p-4
                    shadow-[0_1px_1px_rgba(0,0,0,0.02),0_2px_2px_rgba(0,0,0,0.04)]">
          <div class="w-7 h-7 border border-[#ebebeb] dark:border-[#2e2e2e] rounded-[6px] flex items-center justify-center mb-3">
            <svg class="w-3.5 h-3.5 text-[#171717] dark:text-[#ededed]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
            </svg>
          </div>
          <h2 class="text-[13px] font-semibold text-[#171717] dark:text-[#ededed] mb-0.5 tracking-[-0.2px]">Privacy</h2>
          <p class="text-[12px] text-[#888] dark:text-[#666] leading-relaxed">privacy@spamdetector.app</p>
        </div>
        <div class="bg-white dark:bg-[#111111] rounded-[8px] border border-[#ebebeb] dark:border-[#2e2e2e] p-4
                    shadow-[0_1px_1px_rgba(0,0,0,0.02),0_2px_2px_rgba(0,0,0,0.04)]">
          <div class="w-7 h-7 border border-[#ebebeb] dark:border-[#2e2e2e] rounded-[6px] flex items-center justify-center mb-3">
            <svg class="w-3.5 h-3.5 text-[#171717] dark:text-[#ededed]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h2 class="text-[13px] font-semibold text-[#171717] dark:text-[#ededed] mb-0.5 tracking-[-0.2px]">Response Time</h2>
          <p class="text-[12px] text-[#888] dark:text-[#666] leading-relaxed">We aim to respond within 2 business days.</p>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="sm:col-span-2">
        <div class="bg-white dark:bg-[#111111] rounded-xl border border-[#ebebeb] dark:border-[#2e2e2e]
                    shadow-[0_2px_2px_rgba(0,0,0,0.04),0_8px_16px_-4px_rgba(0,0,0,0.04)] overflow-hidden">
          <div class="px-5 py-4 border-b border-[#ebebeb] dark:border-[#2e2e2e]">
            <span class="text-[13px] font-semibold text-[#171717] dark:text-[#ededed] tracking-[-0.2px]">Send a Message</span>
          </div>
          <form id="contact-form" novalidate class="p-5 space-y-4">

            <!-- Honeypot (hidden from humans) -->
            <input type="text" name="_hp" class="hidden" autocomplete="off" tabindex="-1" aria-hidden="true" />

            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label for="contact-name" class="block text-[13px] font-medium text-[#171717] dark:text-[#ededed] mb-1.5">
                  Full Name <span class="text-[#ee0000]" aria-hidden="true">*</span>
                </label>
                <input
                  type="text" id="contact-name" name="name"
                  required autocomplete="name"
                  class="w-full px-3 h-10 border border-[#ebebeb] dark:border-[#2e2e2e] rounded-[6px]
                         text-[13px] text-[#171717] dark:text-[#ededed] bg-white dark:bg-[#0a0a0a]
                         placeholder:text-[#888] dark:placeholder:text-[#555]
                         focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#171717] dark:focus-visible:ring-[#ededed]
                         focus-visible:border-[#171717] dark:focus-visible:border-[#ededed] transition-colors"
                  placeholder="Jane Smith"
                />
              </div>
              <div>
                <label for="contact-email" class="block text-[13px] font-medium text-[#171717] dark:text-[#ededed] mb-1.5">
                  Email Address <span class="text-[#ee0000]" aria-hidden="true">*</span>
                </label>
                <input
                  type="email" id="contact-email" name="email"
                  required autocomplete="email"
                  class="w-full px-3 h-10 border border-[#ebebeb] dark:border-[#2e2e2e] rounded-[6px]
                         text-[13px] text-[#171717] dark:text-[#ededed] bg-white dark:bg-[#0a0a0a]
                         placeholder:text-[#888] dark:placeholder:text-[#555]
                         focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#171717] dark:focus-visible:ring-[#ededed]
                         focus-visible:border-[#171717] dark:focus-visible:border-[#ededed] transition-colors"
                  placeholder="jane@example.com"
                />
              </div>
            </div>

            <div>
              <label for="contact-subject" class="block text-[13px] font-medium text-[#171717] dark:text-[#ededed] mb-1.5">Subject</label>
              <input
                type="text" id="contact-subject" name="subject"
                autocomplete="off"
                class="w-full px-3 h-10 border border-[#ebebeb] dark:border-[#2e2e2e] rounded-[6px]
                       text-[13px] text-[#171717] dark:text-[#ededed] bg-white dark:bg-[#0a0a0a]
                       placeholder:text-[#888] dark:placeholder:text-[#555]
                       focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#171717] dark:focus-visible:ring-[#ededed]
                       focus-visible:border-[#171717] dark:focus-visible:border-[#ededed] transition-colors"
                placeholder="False positive report, feature request, general question…"
              />
            </div>

            <div>
              <label for="contact-message" class="block text-[13px] font-medium text-[#171717] dark:text-[#ededed] mb-1.5">
                Message <span class="text-[#ee0000]" aria-hidden="true">*</span>
              </label>
              <textarea
                id="contact-message" name="message"
                rows="5" required autocomplete="off"
                class="w-full px-3 py-2.5 border border-[#ebebeb] dark:border-[#2e2e2e] rounded-[6px]
                       text-[13px] text-[#171717] dark:text-[#ededed] bg-white dark:bg-[#0a0a0a]
                       placeholder:text-[#888] dark:placeholder:text-[#555]
                       focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#171717] dark:focus-visible:ring-[#ededed]
                       focus-visible:border-[#171717] dark:focus-visible:border-[#ededed]
                       resize-none transition-colors"
                placeholder="Describe your question or issue in detail…"
              ></textarea>
            </div>

            <!-- Inline error -->
            <div id="form-error" class="hidden rounded-[6px] bg-[#f7d4d6] dark:bg-[#2d1414] border border-[#f7d4d6] dark:border-[#2d1414] px-4 py-3
                                         text-[13px] text-[#c50000] dark:text-[#ff6666]" role="alert" aria-live="polite">
            </div>

            <div class="flex items-center justify-between gap-4 pt-1">
              <p class="text-[12px] text-[#888] dark:text-[#666]"><span class="text-[#ee0000]">*</span> Required fields</p>
              <button
                type="submit" id="submit-btn"
                class="px-6 h-10 bg-[#171717] dark:bg-[#ededed] hover:bg-[#333] dark:hover:bg-white
                       disabled:bg-[#888] dark:disabled:bg-[#333] disabled:cursor-not-allowed
                       text-white dark:text-[#0a0a0a] rounded-full text-[14px] font-medium transition-colors
                       flex items-center gap-2
                       focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#171717] dark:focus-visible:ring-[#ededed] focus-visible:ring-offset-2"
                style="touch-action:manipulation">
                <span id="submit-label">Send Message</span>
                <svg id="submit-spinner" class="hidden motion-safe:animate-spin w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" aria-hidden="true">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                </svg>
              </button>
            </div>
          </form>

          <!-- Success state -->
          <div id="form-success" class="hidden p-5">
            <div class="rounded-[8px] bg-[#f5f5f5] dark:bg-[#1a1a1a] border border-[#ebebeb] dark:border-[#2e2e2e] px-5 py-6 text-center">
              <div class="w-10 h-10 bg-[#171717] dark:bg-[#ededed] rounded-full flex items-center justify-center mx-auto mb-3">
                <svg class="w-5 h-5 text-white dark:text-[#0a0a0a]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <h2 class="text-[15px] font-semibold text-[#171717] dark:text-[#ededed] tracking-[-0.2px] mb-1">Message Sent</h2>
              <p class="text-[13px] text-[#4d4d4d] dark:text-[#a0a0a0]">Thanks for reaching out. We'll get back to you within 2 business days.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  const form    = document.getElementById('contact-form') as HTMLFormElement;
  const errorEl = document.getElementById('form-error')!;
  const success = document.getElementById('form-success')!;
  const btn     = document.getElementById('submit-btn') as HTMLButtonElement;
  const label   = document.getElementById('submit-label')!;
  const spinner = document.getElementById('submit-spinner')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.classList.add('hidden');

    const data = Object.fromEntries(new FormData(form));
    btn.disabled = true;
    label.textContent = 'Sending…';
    spinner.classList.remove('hidden');

    try {
      const res  = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const json = await res.json();

      if (!res.ok) {
        throw new Error(json.error ?? 'Something went wrong. Please try again.');
      }

      form.classList.add('hidden');
      success.classList.remove('hidden');
    } catch (err) {
      errorEl.textContent = err instanceof Error ? err.message : 'Failed to send. Please try again.';
      errorEl.classList.remove('hidden');
      btn.disabled = false;
      label.textContent = 'Send Message';
      spinner.classList.add('hidden');
    }
  });
</script>
