</html>

<script>
  type TabId = 'email' | 'url' | 'comment' | 'image';

  interface Highlight { text: string; type: 'urgency' | 'link' | 'impersonation'; }

  interface DetectionResult {
    isSpam: boolean;
    score: number;
    scamType: string | null;
    explanation: string;
    indicators: string[];
    educationalNote: string | null;
    highlights: Highlight[];
  }

  const MAX_CHARS      = 10_000;
  const MAX_IMG_BYTES  = 10 * 1024 * 1024;
  const MAX_IMG_DIM    = 1280;

  let activeTab: TabId = 'email';
  let imageDataUrl     = '';

  const tabLabels: Record<TabId, string> = {
    email:   'Analyze Email',
    url:     'Scan URL',
    comment: 'Check Comment',
    image:   'Analyze Screenshot',
  };

  // Segment-control active/inactive class sets
  // ── Dark mode toggle ───────────────────────────────────────────────────────
  const html           = document.documentElement;
  const themeToggle    = document.getElementById('theme-toggle') as HTMLButtonElement;
  const iconMoon       = document.getElementById('icon-moon')!;
  const iconSun        = document.getElementById('icon-sun')!;
  const themeColorMeta = document.querySelector('meta[name="theme-color"]') as HTMLMetaElement;

  function applyTheme(dark: boolean) {
    html.classList.toggle('dark', dark);
    iconMoon.classList.toggle('hidden', dark);
    iconSun.classList.toggle('hidden', !dark);
    if (themeColorMeta) themeColorMeta.content = dark ? '#0a0a0a' : '#fafafa';
    themeToggle.setAttribute('aria-label', dark ? 'Switch to light mode' : 'Switch to dark mode');
  }

  // Sync toggle icons with the class already set by the inline FOUC script
  applyTheme(html.classList.contains('dark'));

  themeToggle.addEventListener('click', () => {
    const isDark = html.classList.contains('dark');
    applyTheme(!isDark);
    localStorage.setItem('theme', isDark ? 'light' : 'dark');
  });

  // ── Tab switching ──────────────────────────────────────────────────────────
  const TAB_ORDER: TabId[] = ['email', 'url', 'comment', 'image'];

  document.querySelectorAll<HTMLButtonElement>('.tab-btn').forEach((btn) => {
    btn.addEventListener('click', () => switchTab(btn.dataset.tab as TabId));

    btn.addEventListener('keydown', (e) => {
      const idx = TAB_ORDER.indexOf(btn.dataset.tab as TabId);
      let next = -1;
      if (e.key === 'ArrowRight') next = (idx + 1) % TAB_ORDER.length;
      if (e.key === 'ArrowLeft')  next = (idx - 1 + TAB_ORDER.length) % TAB_ORDER.length;
      if (e.key === 'Home')       next = 0;
      if (e.key === 'End')        next = TAB_ORDER.length - 1;
      if (next >= 0) {
        e.preventDefault();
        switchTab(TAB_ORDER[next]);
        (document.getElementById(`tab-${TAB_ORDER[next]}`) as HTMLButtonElement).focus();
      }
    });
  });

  function switchTab(tab: TabId) {
    activeTab = tab;
    TAB_ORDER.forEach((t) => {
      const btn   = document.getElementById(`tab-${t}`) as HTMLButtonElement;
      const panel = document.getElementById(`panel-${t}`)!;
      const isActive = t === tab;
      btn.classList.toggle('tab-active',   isActive);
      btn.classList.toggle('tab-inactive', !isActive);
      btn.setAttribute('aria-selected', String(isActive));
      panel.classList.toggle('hidden', !isActive);
    });
    (document.getElementById('btn-label') as HTMLSpanElement).textContent = tabLabels[tab];
    clearResults();
  }

  // ── Character counters ─────────────────────────────────────────────────────
  (['email', 'comment'] as const).forEach((t) => {
    const textarea = document.getElementById(`input-${t}`) as HTMLTextAreaElement;
    const counter  = document.getElementById(`counter-${t}`)!;
    textarea.addEventListener('input', () => {
      const len = textarea.value.length;
      counter.textContent = `${len.toLocaleString()} / ${MAX_CHARS.toLocaleString()}`;
      counter.classList.toggle('text-[#ee0000]', len >= MAX_CHARS);
      counter.classList.toggle('text-[#888]', len < MAX_CHARS);
    });
  });

  // ── Image upload ───────────────────────────────────────────────────────────
  const fileInput    = document.getElementById('input-image') as HTMLInputElement;
  const dropZone     = document.getElementById('drop-zone')!;
  const imagePreview = document.getElementById('image-preview')!;
  const previewImg   = document.getElementById('preview-img') as HTMLImageElement;
  const previewName  = document.getElementById('preview-name')!;

  fileInput.addEventListener('change', () => {
    if (fileInput.files?.[0]) handleFile(fileInput.files[0]);
  });
  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.dataset.dragging = '';
  });
  dropZone.addEventListener('dragleave', () => {
    delete dropZone.dataset.dragging;
  });
  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    delete dropZone.dataset.dragging;
    const file = e.dataTransfer?.files[0];
    if (file) handleFile(file);
  });

  document.getElementById('remove-img-btn')!.addEventListener('click', (e) => {
    e.stopPropagation();
    clearImage();
  });

  async function handleFile(file: File) {
    if (!file.type.startsWith('image/')) {
      showError('Please upload an image file (JPEG, PNG, WebP, etc.).');
      return;
    }
    if (file.size > MAX_IMG_BYTES) {
      showError(`Image is too large (${(file.size / 1024 / 1024).toFixed(1)} MB). Please use an image under 10 MB.`);
      return;
    }
    const raw = await readFileAsDataUrl(file);
    imageDataUrl = await resizeImage(raw);
    previewImg.src = imageDataUrl;
    previewName.textContent = `${file.name} · ${(file.size / 1024).toFixed(0)} KB`;
    imagePreview.classList.remove('hidden');
    dropZone.classList.add('hidden');
    clearResults();
  }

  function clearImage() {
    imageDataUrl = '';
    fileInput.value = '';
    previewImg.src = '';
    previewName.textContent = '';
    imagePreview.classList.add('hidden');
    dropZone.classList.remove('hidden');
  }

  function readFileAsDataUrl(file: File): Promise<string> {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload  = () => resolve(reader.result as string);
      reader.onerror = () => reject(new Error('Failed to read file'));
      reader.readAsDataURL(file);
    });
  }

  function resizeImage(dataUrl: string): Promise<string> {
    return new Promise((resolve) => {
      const img = new Image();
      img.onload = () => {
        if (img.width <= MAX_IMG_DIM && img.height <= MAX_IMG_DIM) { resolve(dataUrl); return; }
        const scale = MAX_IMG_DIM / Math.max(img.width, img.height);
        const canvas = document.createElement('canvas');
        canvas.width  = Math.round(img.width  * scale);
        canvas.height = Math.round(img.height * scale);
        canvas.getContext('2d')!.drawImage(img, 0, 0, canvas.width, canvas.height);
        resolve(canvas.toDataURL('image/jpeg', 0.85));
      };
      img.src = dataUrl;
    });
  }

  // ── Clear button ───────────────────────────────────────────────────────────
  document.getElementById('clear-btn')!.addEventListener('click', () => {
    if (activeTab === 'image') {
      clearImage();
    } else {
      (document.getElementById(`input-${activeTab}`) as HTMLInputElement | HTMLTextAreaElement).value = '';
      if (activeTab !== 'url') {
        const counter = document.getElementById(`counter-${activeTab}`)!;
        counter.textContent = `0 / ${MAX_CHARS.toLocaleString()}`;
        counter.classList.remove('text-[#ee0000]');
        counter.classList.add('text-[#888]');
      }
    }
    clearResults();
  });

  function clearResults() {
    const el = document.getElementById('results')!;
    el.classList.add('hidden');
    el.innerHTML = '';
  }

  // ── Detection ──────────────────────────────────────────────────────────────
  document.getElementById('detect-btn')!.addEventListener('click', async () => {
    const content = getInput(activeTab).trim();

    if (!content) {
      showError(activeTab === 'image' ? 'Please upload a screenshot first.' : 'Please enter content to analyze.');
      return;
    }
    if (activeTab === 'url') {
      try { new URL(content); } catch {
        showError('Please enter a valid URL including http:// or https://');
        return;
      }
    }
    if (activeTab !== 'image' && content.length > MAX_CHARS) {
      showError(`Content is too long. Please keep it under ${MAX_CHARS.toLocaleString()} characters.`);
      return;
    }

    const submittedTab     = activeTab;
    const submittedContent = content;

    setLoading(true);
    try {
      const res  = await fetch('/api/detect', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ type: submittedTab, content: submittedContent }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error ?? 'Request failed');
      renderResult(data as DetectionResult, submittedContent, submittedTab);
    } catch (err) {
      showError(err instanceof Error ? err.message : 'Something went wrong. Please try again.');
    } finally {
      setLoading(false);
    }
  });

  function getInput(tab: TabId): string {
    if (tab === 'image') return imageDataUrl;
    return (document.getElementById(`input-${tab}`) as HTMLInputElement | HTMLTextAreaElement)?.value ?? '';
  }

  function setLoading(loading: boolean) {
    const btn     = document.getElementById('detect-btn') as HTMLButtonElement;
    const label   = document.getElementById('btn-label')!;
    const spinner = document.getElementById('btn-spinner')!;
    btn.disabled = loading;
    label.textContent = loading ? 'Analyzing…' : tabLabels[activeTab];
    spinner.classList.toggle('hidden', !loading);
  }

  // ── Results rendering ──────────────────────────────────────────────────────
  function renderResult(data: DetectionResult, rawContent: string, tab: TabId) {
    const resultsEl = document.getElementById('results')!;
    const { isSpam, score, scamType, explanation, indicators, educationalNote, highlights } = data;

    const isDangerous  = score >= 70;
    const isSuspicious = score >= 40;
    const tierLabel = isDangerous ? 'Dangerous'  : isSuspicious ? 'Suspicious' : 'Safe';
    const tierDot   = isDangerous ? 'bg-[#ee0000]'  : isSuspicious ? 'bg-[#f5a623]' : 'bg-[#1a7f4b]';
    const tierText  = isDangerous ? 'text-[#c50000]' : isSuspicious ? 'text-[#ab570a]' : 'text-[#1a7f4b]';
    const tierBar   = isDangerous ? 'bg-[#ee0000]'   : isSuspicious ? 'bg-[#f5a623]'   : 'bg-[#1a7f4b]';
    const tierBg    = isDangerous ? 'bg-[#f7d4d6]'   : isSuspicious ? 'bg-[#ffefcf]'   : 'bg-[#f5f5f5]';

    const verdictBadge = isSpam
      ? `<span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-[12px] font-medium bg-[#f7d4d6] text-[#c50000]">
           <span class="w-1.5 h-1.5 rounded-full bg-[#ee0000] inline-block"></span>Spam Detected
         </span>`
      : `<span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-[12px] font-medium bg-[#f5f5f5] text-[#4d4d4d]">
           <span class="w-1.5 h-1.5 rounded-full bg-[#1a7f4b] inline-block"></span>Looks Clean
         </span>`;

    const scamHtml = scamType
      ? `<div class="rounded-[6px] ${tierBg} px-4 py-3 space-y-1">
           <p class="font-mono text-[10px] text-[#888] uppercase tracking-widest">Scam Type</p>
           <p class="text-[13px] font-semibold ${tierText} tracking-[-0.2px]">${escapeHtml(scamType)}</p>
           ${educationalNote
             ? `<p class="text-[12px] text-[#4d4d4d] leading-relaxed pt-0.5">
                  <span class="font-medium">Stay safe:</span> ${escapeHtml(educationalNote)}
                </p>`
             : ''}
         </div>`
      : '';

    const indicatorHtml = indicators.length > 0
      ? `<div>
           <p class="font-mono text-[10px] text-[#888] uppercase tracking-widest mb-2">Indicators</p>
           <ul class="space-y-1.5">
             ${indicators.map((ind) => `
               <li class="flex items-start gap-2 text-[13px] text-[#4d4d4d]">
                 <svg class="w-3.5 h-3.5 text-[#888] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                   <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                 </svg>
                 ${escapeHtml(ind)}
               </li>`).join('')}
           </ul>
         </div>`
      : '';

    const showHighlight = (tab === 'email' || tab === 'comment') && highlights.length > 0;
    const highlightHtml = showHighlight
      ? `<div>
           <p class="font-mono text-[10px] text-[#888] uppercase tracking-widest mb-2">Evidence</p>
           <div class="font-mono text-[11px] leading-relaxed bg-[#fafafa] border border-[#ebebeb] rounded-[6px] p-3 max-h-48 overflow-y-auto whitespace-pre-wrap break-words text-[#4d4d4d]">${highlightText(rawContent, highlights)}</div>
           <p class="mt-1.5 font-mono text-[10px] text-[#888] flex items-center gap-3 flex-wrap">
             <span class="inline-flex items-center gap-1"><span class="inline-block w-2 h-2 rounded-sm bg-[#f7d4d6]"></span>Urgency</span>
             <span class="inline-flex items-center gap-1"><span class="inline-block w-2 h-2 rounded-sm bg-[#ffefcf]"></span>Link</span>
             <span class="inline-flex items-center gap-1"><span class="inline-block w-2 h-2 rounded-sm bg-[#d8ccf1]"></span>Impersonation</span>
           </p>
         </div>`
      : '';

    resultsEl.innerHTML = `
      <div class="bg-white dark:bg-[#111111] rounded-xl border border-[#ebebeb] dark:border-[#2e2e2e] shadow-[0_2px_2px_rgba(0,0,0,0.04),0_8px_16px_-4px_rgba(0,0,0,0.04)] dark:shadow-[0_2px_2px_rgba(0,0,0,0.3),0_8px_16px_-4px_rgba(0,0,0,0.3)] overflow-hidden">
        <div class="px-5 py-3.5 border-b border-[#ebebeb] flex items-center justify-between gap-3">
          <span class="text-[13px] font-semibold text-[#171717] tracking-[-0.2px]">Analysis Result</span>
          ${verdictBadge}
        </div>
        <div class="p-5 space-y-4">
          <div>
            <div class="flex items-center justify-between mb-2">
              <span class="font-mono text-[10px] text-[#888] uppercase tracking-widest">Risk Score</span>
              <span class="inline-flex items-center gap-1.5 text-[13px] font-medium ${tierText}">
                <span class="w-1.5 h-1.5 rounded-full ${tierDot} inline-block"></span>
                ${tierLabel}&nbsp;&middot;&nbsp;${score}/100
              </span>
            </div>
            <div class="h-1 w-full bg-[#f5f5f5] rounded-full overflow-hidden">
              <div class="h-full ${tierBar} rounded-full motion-safe:transition-all motion-safe:duration-700" style="width:${score}%"></div>
            </div>
          </div>
          ${scamHtml}
          <div>
            <p class="font-mono text-[10px] text-[#888] uppercase tracking-widest mb-1.5">Analysis</p>
            <p class="text-[13px] text-[#4d4d4d] leading-relaxed">${escapeHtml(explanation)}</p>
          </div>
          ${indicatorHtml}
          ${highlightHtml}
        </div>
      </div>`;

    resultsEl.classList.remove('hidden');
    resultsEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  // ── Text highlighting ──────────────────────────────────────────────────────
  function escapeRegex(s: string): string {
    return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  }

  function highlightText(raw: string, hl: Highlight[]): string {
    type IV = { start: number; end: number; type: Highlight['type'] };
    const ivs: IV[] = [];
    for (const h of hl) {
      const re = new RegExp(escapeRegex(h.text), 'gi');
      let m: RegExpExecArray | null;
      while ((m = re.exec(raw)) !== null) ivs.push({ start: m.index, end: m.index + m[0].length, type: h.type });
    }
    ivs.sort((a, b) => a.start - b.start);
    const merged: IV[] = [];
    let lastEnd = 0;
    for (const iv of ivs) { if (iv.start >= lastEnd) { merged.push(iv); lastEnd = iv.end; } }
    const cls: Record<Highlight['type'], string> = {
      urgency:       'bg-[#f7d4d6] text-[#c50000] rounded px-0.5',
      link:          'bg-[#ffefcf] text-[#ab570a] rounded px-0.5',
      impersonation: 'bg-[#d8ccf1] text-[#4c2889] rounded px-0.5',
    };
    let html = '', pos = 0;
    for (const iv of merged) {
      html += escapeHtml(raw.slice(pos, iv.start));
      html += `<mark class="${cls[iv.type]}">${escapeHtml(raw.slice(iv.start, iv.end))}</mark>`;
      pos = iv.end;
    }
    return html + escapeHtml(raw.slice(pos));
  }

  function showError(message: string) {
    const resultsEl = document.getElementById('results')!;
    resultsEl.innerHTML = `
      <div class="bg-[#f7d4d6] border border-[#f7d4d6] rounded-xl p-5 flex items-start gap-3">
        <svg class="w-4 h-4 text-[#ee0000] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <div>
          <p class="text-[13px] font-semibold text-[#c50000]">Detection Failed</p>
          <p class="text-[12px] text-[#4d4d4d] mt-0.5">${escapeHtml(message)}</p>
        </div>
      </div>`;
    resultsEl.classList.remove('hidden');
  }

  function escapeHtml(str: string): string {
    return str
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;');
  }
</script>
