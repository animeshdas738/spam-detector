      <!-- FAQ Section -->
      <section aria-labelledby="faq-heading" class="space-y-4 pt-2">
        <div>
          <p class="font-mono text-[10px] text-[#888] dark:text-[#666] uppercase tracking-widest mb-1.5">Knowledge Base</p>
          <h2 id="faq-heading" class="text-[20px] font-semibold text-[#171717] dark:text-[#ededed] tracking-[-0.5px] text-pretty">
