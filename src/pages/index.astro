---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#fafafa" id="theme-color-meta" />
    <title>Spam Detector — Free Phishing &amp; Spam Risk Scanner | AI-Powered</title>
    <meta name="description" content="Detect phishing emails, phishing links, and potential spam instantly. Our free AI tool scores spam risk, identifies phishing software patterns, screens spam calls, and helps you stay safe online." />
    <meta name="keywords" content="spam detector, phishing, spam, phishing email, phishing link, phishing software, potential spam, spam risk, spam calls, how to block spam calls, pishing, pishing email, pishing link, pishing software" />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Spam Detector" />
    <link rel="canonical" href="https://spamdetector.app/" />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://spamdetector.app/" />
    <meta property="og:site_name" content="Spam Detector" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content="Spam Detector — Free Phishing &amp; Spam Risk Scanner" />
    <meta property="og:description" content="Detect phishing emails, phishing links, and potential spam instantly with AI. Get a spam risk score, scam type identification, and tips to block spam calls — free, no sign-up required." />
    <meta property="og:image" content="https://spamdetector.app/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Spam Detector — AI-powered phishing and spam risk scanner" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Spam Detector — Free Phishing &amp; Spam Risk Scanner" />
    <meta name="twitter:description" content="Detect phishing emails, phishing links, and potential spam with AI. Instant spam risk scores. Free, no sign-up." />
    <meta name="twitter:image" content="https://spamdetector.app/og-image.png" />
    <meta name="twitter:image:alt" content="Spam Detector — AI-powered phishing and spam risk scanner" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="SpamCheck" />
    <link rel="manifest" href="/site.webmanifest" />
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />
    <!-- WebApplication structured data -->
    <script is:inline type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Spam Detector",
      "url": "https://spamdetector.app/",
      "description": "Free AI-powered tool to detect phishing emails, phishing links, potential spam, spam risk, and spam calls. Analyses email text, URLs, comments, and screenshots.",
      "applicationCategory": "SecurityApplication",
      "operatingSystem": "Any",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "keywords": "phishing, spam, phishing email, phishing link, phishing software, potential spam, spam risk, spam calls",
      "browserRequirements": "Requires JavaScript",
      "creator": { "@type": "Organization", "name": "Spam Detector" }
    }
    </script>
    <!-- FAQ structured data -->
    <script is:inline type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is spam?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Spam refers to unsolicited bulk messages sent over the internet without the recipient's consent, typically for advertising, phishing, spreading malware, or committing fraud. Email spam accounts for nearly half of all global email traffic. Spam also appears as text messages (SMS spam), robocalls, social media messages, and comment spam on websites. Common signs include suspicious sender addresses, urgent or threatening language, too-good-to-be-true offers, requests for personal information, and links to unfamiliar domains."
          }
        },
        {
          "@type": "Question",
          "name": "How to block spam calls?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "To block spam calls: (1) Register on your country's Do Not Call list — in the US, visit donotcall.gov. (2) Use your carrier's built-in call-screening service; most major carriers offer this free. (3) Enable your phone's native spam protection: on Android, open the Phone app → Settings → Spam and Call Screen; on iPhone, go to Settings → Phone → Silence Unknown Callers. (4) Install a third-party call-blocking app such as Hiya, Nomorobo, or Robokiller. (5) Never press any keys in response to automated prompts, as this confirms your number is active and can increase the volume of spam calls you receive."
          }
        },
        {
          "@type": "Question",
          "name": "How to stop spam emails?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "To reduce spam emails: (1) Never share your primary email address publicly — use a secondary or disposable address for sign-ups and newsletters. (2) Unsubscribe from legitimate mailing lists using the unsubscribe link at the bottom of emails. (3) Mark unwanted messages as Junk or Spam to train your email client's filter. (4) Use an email provider with strong built-in filtering such as Gmail or Outlook. (5) Enable two-factor authentication on your email account to prevent takeovers that generate outbound spam. (6) Never click links or download attachments in suspicious emails — doing so can subscribe you to additional spam lists or install malware."
          }
        },
        {
          "@type": "Question",
          "name": "What is phishing?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Phishing is a cyberattack in which criminals impersonate trusted organisations — such as banks, tech companies, or government agencies — to trick victims into revealing sensitive information like passwords, credit card numbers, or Social Security numbers. Phishing attacks arrive most commonly via email, but also occur through SMS messages (smishing) and phone calls (vishing). Warning signs include urgent or threatening language, generic greetings like 'Dear Customer', misspelled domain names, requests to click a link and log in, and unexpected attachments. To protect yourself, always verify the sender's email address, hover over links before clicking to check the destination, and type website URLs directly into your browser rather than following links in emails."
          }
        }
      ]
    }
    </script>
    <!-- Prevent flash of wrong theme before first paint -->
    <script is:inline>
      (function(){var s=localStorage.getItem('theme'),d=window.matchMedia('(prefers-color-scheme: dark)').matches;if(s==='dark'||(!s&&d))document.documentElement.classList.add('dark')})();
    </script>
  </head>

  <body class="bg-[#fafafa] dark:bg-[#0a0a0a] min-h-screen font-sans antialiased transition-colors duration-200">

    <!-- Skip link -->
    <a href="#main-content"
       class="sr-only focus-visible:not-sr-only focus-visible:fixed focus-visible:top-4 focus-visible:left-4 focus-visible:z-50
              focus-visible:px-4 focus-visible:py-2 focus-visible:bg-[#171717] focus-visible:text-white focus-visible:rounded-full
              focus-visible:text-sm focus-visible:font-medium">
      Skip to main content
    </a>

    <!-- Mesh gradient backdrop — atmospheric, hero-scale only -->
    <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden" aria-hidden="true">
      <div class="absolute -top-1/2 left-1/2 -translate-x-1/2 w-[900px] h-[700px] opacity-30 dark:opacity-20"
           style="background:radial-gradient(ellipse at 20% 40%,#007cf0 0%,transparent 55%),radial-gradient(ellipse at 80% 20%,#7928ca 0%,transparent 55%),radial-gradient(ellipse at 60% 80%,#ff4d4d 0%,transparent 55%),radial-gradient(ellipse at 30% 70%,#00dfd8 0%,transparent 55%);filter:blur(90px)">
      </div>
    </div>

    <!-- Header -->
    <header class="sticky top-0 z-40 bg-[#fafafa]/80 dark:bg-[#0a0a0a]/80 backdrop-blur-md border-b border-[#ebebeb] dark:border-[#2e2e2e]">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
        <div class="flex items-center gap-2.5">
          <div class="w-7 h-7 bg-[#171717] dark:bg-[#ededed] rounded-[6px] flex items-center justify-center flex-shrink-0">
            <svg class="w-3.5 h-3.5 text-white dark:text-[#0a0a0a]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <span class="text-[15px] font-semibold tracking-[-0.3px] text-[#171717] dark:text-[#ededed] text-pretty">Spam Detector</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="font-mono text-[11px] text-[#888] dark:text-[#666] tracking-wide hidden sm:block" translate="no">Powered by OpenAI</span>
          <button
            type="button" id="theme-toggle"
            class="w-8 h-8 flex items-center justify-center rounded-[6px]
                   border border-[#ebebeb] dark:border-[#2e2e2e]
                   text-[#888] dark:text-[#666] hover:text-[#171717] dark:hover:text-[#ededed]
                   hover:bg-[#f5f5f5] dark:hover:bg-[#1a1a1a] transition-colors
                   focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#171717] dark:focus-visible:ring-[#ededed]"
            style="touch-action:manipulation" aria-label="Switch to dark mode">
            <!-- Moon — shown in light mode -->
            <svg id="icon-moon" class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
            </svg>
            <!-- Sun — shown in dark mode -->
            <svg id="icon-sun" class="w-3.5 h-3.5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
            </svg>
          </button>
        </div>
      </div>
    </header>

    <!-- Main -->
    <main id="main-content" class="max-w-3xl mx-auto px-4 sm:px-6 py-10 space-y-4">

      <!-- Detection Card -->
      <div class="bg-white dark:bg-[#111111] rounded-xl border border-[#ebebeb] dark:border-[#2e2e2e] shadow-[0_2px_2px_rgba(0,0,0,0.04),0_8px_16px_-4px_rgba(0,0,0,0.04)] dark:shadow-[0_2px_2px_rgba(0,0,0,0.3),0_8px_16px_-4px_rgba(0,0,0,0.3)] overflow-hidden">

        <!-- Segment Tab Bar -->
        <div class="px-4 pt-4">
          <div class="flex bg-[#f5f5f5] dark:bg-[#1a1a1a] rounded-[8px] p-0.5 gap-0.5" role="tablist" aria-label="Content type to analyze">
            <button
              type="button" id="tab-email" role="tab"
              aria-selected="true" aria-controls="panel-email" data-tab="email"
              class="tab-btn tab-active flex-1 flex items-center justify-center gap-1.5 px-2 py-1.5 rounded-[6px]
                     text-[13px] font-medium transition-all duration-150
                     focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#171717] dark:focus-visible:ring-[#ededed] focus-visible:ring-offset-1"
            >
              <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              <span class="hidden sm:inline">Email / Text</span>
              <span class="sm:hidden">Email</span>
            </button>
            <button
              type="button" id="tab-url" role="tab"
              aria-selected="false" aria-controls="panel-url" data-tab="url"
              class="tab-btn tab-inactive flex-1 flex items-center justify-center gap-1.5 px-2 py-1.5 rounded-[6px]
                     text-[13px] font-medium transition-all duration-150
                     focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#171717] dark:focus-visible:ring-[#ededed] focus-visible:ring-offset-1"
            >
              <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
              </svg>
              <span class="hidden sm:inline">URL Scanner</span>
              <span class="sm:hidden">URL</span>
            </button>
            <button
              type="button" id="tab-comment" role="tab"
              aria-selected="false" aria-controls="panel-comment" data-tab="comment"
              class="tab-btn tab-inactive flex-1 flex items-center justify-center gap-1.5 px-2 py-1.5 rounded-[6px]
                     text-[13px] font-medium transition-all duration-150
                     focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#171717] dark:focus-visible:ring-[#ededed] focus-visible:ring-offset-1"
            >
              <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
              </svg>
              <span class="hidden sm:inline">Comment</span>
              <span class="sm:hidden">Comment</span>
            </button>
            <button
              type="button" id="tab-image" role="tab"
              aria-selected="false" aria-controls="panel-image" data-tab="image"
              class="tab-btn tab-inactive flex-1 flex items-center justify-center gap-1.5 px-2 py-1.5 rounded-[6px]
                     text-[13px] font-medium transition-all duration-150
                     focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#171717] dark:focus-visible:ring-[#ededed] focus-visible:ring-offset-1"
            >
              <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
              <span class="hidden sm:inline">Screenshot</span>
              <span class="sm:hidden">Image</span>
            </button>
          </div>
        </div>

        <!-- Panels -->
        <div class="p-5 pt-4 space-y-4">

          <!-- Email Panel -->
          <div id="panel-email" role="tabpanel" aria-labelledby="tab-email">
            <div class="flex items-center justify-between mb-1.5">
              <label for="input-email" class="text-[13px] font-medium text-[#171717] dark:text-[#ededed]">
                Paste email or suspicious text
              </label>
              <span id="counter-email" class="font-mono text-[11px] text-[#888] dark:text-[#666]">0 / 10,000</span>
            </div>
            <textarea
              id="input-email"
              name="email-content"
              rows="7"
              maxlength="10000"
              autocomplete="off"
              spellcheck="false"
              class="w-full px-3 py-2.5 border border-[#ebebeb] dark:border-[#2e2e2e] rounded-[6px] text-[13px] font-mono text-[#171717] dark:text-[#ededed] bg-white dark:bg-[#0a0a0a]
                     placeholder:text-[#888] dark:placeholder:text-[#555]
                     focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#171717] dark:focus-visible:ring-[#ededed] focus-visible:border-[#171717] dark:focus-visible:border-[#ededed]
                     resize-none transition-colors"
              placeholder="Subject: You've been selected for a $1,000,000 prize!&#10;&#10;Dear Winner, your email was randomly selected…"
            ></textarea>
          </div>

          <!-- URL Panel -->
          <div id="panel-url" role="tabpanel" aria-labelledby="tab-url" class="hidden">
            <label for="input-url" class="block text-[13px] font-medium text-[#171717] dark:text-[#ededed] mb-1.5">
              Enter a URL to check for phishing
            </label>
            <input
              type="url"
              id="input-url"
              name="url-content"
              autocomplete="url"
              spellcheck="false"
              class="w-full px-3 h-10 border border-[#ebebeb] dark:border-[#2e2e2e] rounded-[6px] text-[13px] text-[#171717] dark:text-[#ededed] bg-white dark:bg-[#0a0a0a]
                     placeholder:text-[#888] dark:placeholder:text-[#555]
                     focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#171717] dark:focus-visible:ring-[#ededed] focus-visible:border-[#171717] dark:focus-visible:border-[#ededed]
                     transition-colors"
              placeholder="https://suspicious-domain.xyz/click-here?ref=prize…"
            />
            <p class="mt-1.5 font-mono text-[11px] text-[#888]">Include the full URL with http:// or https://</p>
          </div>

          <!-- Comment Panel -->
          <div id="panel-comment" role="tabpanel" aria-labelledby="tab-comment" class="hidden">
            <div class="flex items-center justify-between mb-1.5">
              <label for="input-comment" class="text-[13px] font-medium text-[#171717] dark:text-[#ededed]">
                Paste a comment or form submission
              </label>
              <span id="counter-comment" class="font-mono text-[11px] text-[#888] dark:text-[#666]">0 / 10,000</span>
            </div>
            <textarea
              id="input-comment"
              name="comment-content"
              rows="7"
              maxlength="10000"
              autocomplete="off"
              class="w-full px-3 py-2.5 border border-[#ebebeb] dark:border-[#2e2e2e] rounded-[6px] text-[13px] text-[#171717] dark:text-[#ededed] bg-white dark:bg-[#0a0a0a]
                     placeholder:text-[#888] dark:placeholder:text-[#555]
                     focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#171717] dark:focus-visible:ring-[#ededed] focus-visible:border-[#171717] dark:focus-visible:border-[#ededed]
                     resize-none transition-colors"
              placeholder="Great post!! Amazing deals at cheap-stuff-deals.com — 90% OFF everything!!! Click NOW before it expires…"
            ></textarea>
          </div>

          <!-- Image Panel -->
          <div id="panel-image" role="tabpanel" aria-labelledby="tab-image" class="hidden">
            <label class="block text-[13px] font-medium text-[#171717] dark:text-[#ededed] mb-1.5">
              Upload a screenshot to check for spam or phishing
            </label>
            <!-- Drop zone -->
            <div
              id="drop-zone"
              class="relative border border-dashed border-[#a1a1a1] dark:border-[#444444] rounded-[6px] p-8 text-center cursor-pointer
                     hover:border-[#171717] dark:hover:border-[#ededed] hover:bg-[#fafafa] dark:hover:bg-[#1a1a1a] transition-colors"
            >
              <input
                type="file"
                id="input-image"
                name="image-content"
                accept="image/*"
                class="absolute inset-0 w-full h-full opacity-0 cursor-pointer"
                aria-label="Upload screenshot image"
              />
              <div id="drop-idle" class="pointer-events-none space-y-2">
                <div class="w-9 h-9 border border-[#ebebeb] dark:border-[#2e2e2e] rounded-[8px] flex items-center justify-center mx-auto bg-white dark:bg-[#1a1a1a] shadow-[0_1px_2px_rgba(0,0,0,0.06)]">
                  <svg class="w-4 h-4 text-[#888] dark:text-[#666]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
                  </svg>
                </div>
                <p class="text-[13px] font-medium text-[#171717] dark:text-[#ededed]">Drag & drop or click to upload</p>
                <p class="font-mono text-[11px] text-[#888] dark:text-[#666]">JPEG, PNG, WebP · Max&nbsp;10&nbsp;MB</p>
              </div>
            </div>
            <!-- Preview -->
            <div id="image-preview" class="hidden mt-3 relative">
              <img
                id="preview-img"
                width="800" height="600"
                class="w-full max-h-56 object-contain rounded-[6px] border border-[#ebebeb] dark:border-[#2e2e2e] bg-[#fafafa] dark:bg-[#1a1a1a]"
                alt="Uploaded screenshot preview"
              />
              <button
                type="button"
                id="remove-img-btn"
                class="absolute top-2 right-2 w-8 h-8 bg-white dark:bg-[#1a1a1a] border border-[#ebebeb] dark:border-[#2e2e2e] rounded-full
                       flex items-center justify-center text-[#888] dark:text-[#666] hover:text-[#ee0000] hover:border-[#ee0000]
                       transition-colors shadow-[0_1px_2px_rgba(0,0,0,0.06)]
                       focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#171717] dark:focus-visible:ring-[#ededed]"
                style="touch-action:manipulation"
                aria-label="Remove uploaded image"
              >
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/>
                </svg>
              </button>
              <p id="preview-name" class="mt-1.5 font-mono text-[11px] text-[#888] truncate min-w-0"></p>
            </div>
          </div>

          <!-- Action Row -->
          <div class="flex gap-2 pt-1">
            <button
              type="button"
              id="clear-btn"
              class="px-5 h-10 min-w-[80px] border border-[#ebebeb] dark:border-[#2e2e2e] bg-white dark:bg-transparent hover:bg-[#fafafa] dark:hover:bg-[#1a1a1a] active:bg-[#f5f5f5] dark:active:bg-[#2e2e2e]
                     text-[#171717] dark:text-[#ededed] rounded-full text-[14px] font-medium transition-colors
                     focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#171717] dark:focus-visible:ring-[#ededed] focus-visible:ring-offset-1"
              style="touch-action:manipulation"
            >
              Clear
            </button>
            <button
              type="button"
              id="detect-btn"
              class="flex-1 h-10 bg-[#171717] dark:bg-[#ededed] hover:bg-[#333] dark:hover:bg-white active:bg-[#000] dark:active:bg-[#d0d0d0] disabled:bg-[#888] dark:disabled:bg-[#333] disabled:cursor-not-allowed
