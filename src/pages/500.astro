---
// Self-contained — avoids Layout in case the server error is widespread
interface Props { error: unknown; }
const { error } = Astro.props;

// Log server-side for debugging; never expose stack traces to the client
if (error instanceof Error) {
  console.error('[500]', error.message);
}
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#fafafa" id="theme-color-meta" />
    <title>500 — Server Error | Spam Detector</title>
    <meta name="description" content="An unexpected error occurred on our server. Please try again in a moment." />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, sans-serif;
        background: #fafafa; color: #171717;
        min-height: 100dvh; display: flex; flex-direction: column;
        -webkit-font-smoothing: antialiased;
        transition: background-color 0.2s, color 0.2s;
      }
      .dark body { background: #0a0a0a; color: #ededed; }
      .dark { color-scheme: dark; }
    </style>
    <script is:inline>
      (function(){var s=localStorage.getItem('theme'),d=window.matchMedia('(prefers-color-scheme: dark)').matches;if(s==='dark'||(!s&&d))document.documentElement.classList.add('dark')})();
    </script>
  </head>

  <body style="background:var(--bg,#fafafa);font-family:Inter,ui-sans-serif,system-ui,-apple-system,sans-serif;min-height:100dvh;display:flex;flex-direction:column;-webkit-font-smoothing:antialiased;">

    <!-- Header -->
    <header style="border-bottom:1px solid #ebebeb;background:rgba(250,250,250,0.8);backdrop-filter:blur(12px);position:sticky;top:0;z-index:40;">
      <div style="max-width:768px;margin:0 auto;padding:0 1.5rem;height:4rem;display:flex;align-items:center;justify-content:space-between;">
        <a href="/" style="display:flex;align-items:center;gap:10px;text-decoration:none;">
          <div style="width:28px;height:28px;background:#171717;border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg width="14" height="14" fill="none" stroke="white" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <span style="font-size:15px;font-weight:600;letter-spacing:-0.3px;color:#171717;">Spam Detector</span>
        </a>
      </div>
    </header>

    <!-- Content -->
    <main id="main-content" style="flex:1;display:flex;align-items:center;justify-content:center;padding:5rem 1.5rem;">
      <div style="text-align:center;max-width:28rem;">

        <p style="font-family:ui-monospace,monospace;font-size:clamp(72px,10vw,96px);font-weight:600;line-height:1;color:#ebebeb;user-select:none;margin-bottom:1.5rem;" aria-hidden="true">500</p>

        <div style="width:48px;height:48px;background:#f5f5f5;border-radius:12px;display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;">
          <svg width="24" height="24" fill="none" stroke="#888" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
              d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>

        <h1 style="font-size:22px;font-weight:600;letter-spacing:-0.5px;margin-bottom:8px;">Server Error</h1>
        <p style="font-size:14px;color:#888;line-height:1.6;margin-bottom:2rem;">
          Something went wrong on our end. This is temporary — please wait a moment and try again.
          If the problem persists, <a href="/contact" style="color:#171717;text-decoration:underline;text-underline-offset:2px;">contact us</a>.
        </p>

        <div style="display:flex;flex-direction:column;gap:12px;align-items:center;">
          <a href="/"
             style="display:inline-flex;align-items:center;gap:8px;padding:0 24px;height:40px;
                    background:#171717;color:white;border-radius:100px;font-size:14px;font-weight:500;
                    text-decoration:none;transition:background 0.15s;">
            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
            </svg>
            Back to Home
          </a>
          <button
            onclick="window.location.reload()"
            style="display:inline-flex;align-items:center;padding:0 24px;height:40px;
                   background:transparent;border:1px solid #ebebeb;color:#171717;border-radius:100px;
                   font-size:14px;font-weight:500;cursor:pointer;transition:background 0.15s;font-family:inherit;"
          >
            Try Again
          </button>
        </div>

      </div>
    </main>

    <!-- Minimal footer -->
    <footer style="border-top:1px solid #ebebeb;padding:1.5rem;text-align:center;">
      <p style="font-size:12px;color:#888;">
        &copy; {new Date().getFullYear()} Spam Detector &nbsp;&middot;&nbsp;
        <a href="/privacy" style="color:#888;text-decoration:none;">Privacy</a> &nbsp;&middot;&nbsp;
        <a href="/terms"   style="color:#888;text-decoration:none;">Terms</a>
      </p>
    </footer>

  </body>
</html>
